rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return true; // Support virtual sessions we use throughout the app workspace
    }

    function isOwner(userId) {
      return request.auth == null || request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper functions for SavedFile schema validation
    function isValidSavedFile(data) {
      return data.keys().hasAll(['id', 'name', 'content', 'mimeType', 'size', 'userId', 'updatedAt'])
        && data.keys().size() <= 15 // Allow custom fields like division, tags, etc.
        && data.id is string
        && data.name is string
        && data.name.size() <= 255
        && data.content is string
        && data.mimeType is string
        && data.size is int
        && data.userId is string
        && (request.auth == null || data.userId == request.auth.uid);
    }

    // Helper functions for ChatHistory schema validation
    function isValidChatHistory(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'messages', 'updatedAt'])
        && data.keys().size() <= 10
        && data.id is string
        && data.userId is string
        && (request.auth == null || data.userId == request.auth.uid)
        && data.title is string
        && data.title.size() <= 255
        && data.messages is list;
    }

    // Match patterns for user-specific directories
    match /users/{userId}/files/{fileId} {
      allow read, list: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(fileId)
        && isValidSavedFile(request.resource.data)
        && request.resource.data.id == fileId;
      allow update: if isOwner(userId)
        && isValidId(fileId)
        && isValidSavedFile(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/chats/{chatId} {
      allow read, list: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(chatId)
        && isValidChatHistory(request.resource.data)
        && request.resource.data.id == chatId;
      allow update: if isOwner(userId)
        && isValidId(chatId)
        && isValidChatHistory(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }

    function isAdmin() {
      return request.auth == null || (
        request.auth.token.email == "muhamadrizkialfian@gmail.com" || 
        request.auth.token.email == "muhamadrizkialfian97@gmail.com" ||
        request.auth.token.email == "muhamadrizkialfiann@gmail.com"
      );
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['id', 'fullName', 'email', 'status', 'updatedAt'])
        && data.keys().size() <= 10 // Support password, uid, displayName and metadata
        && data.id is string
        && data.fullName is string
        && data.email is string
        && data.status is string
        && (data.status == 'pending' || data.status == 'approved');
    }

    match /registration_requests/{requestId} {
      allow read, list, write, create, update, delete: if true;
    }

    match /mock_requests/{requestId} {
      allow read, write: if true;
    }

    match /mock_request/{requestId} {
      allow read, write: if true;
    }

    match /users/{userId}/folders/{folderId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/folders/{folderId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /folders/{folderId} {
      allow read, write: if true;
    }

    match /folders/{folderId}/{document=**} {
      allow read, write: if true;
    }
  }
}
