{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/((?!api/|.*\\.mp4|.*\\.mov|.*\\.webm|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.gif|.*\\.svg|.*\\.webp|.*\\.ico|.*\\.html|.*\\.js|.*\\.css|.*\\.json|.*\\.docx|.*\\.doc|.*\\.pptx|.*\\.ppt|.*\\.xlsx|.*\\.xls|.*\\.pdf).*)",
      "destination": "/index.html"
    }
  ]
}
